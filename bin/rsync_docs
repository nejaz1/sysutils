#!/usr/bin/env zsh
# Syncs ~/Documents/MyDocs to /Volumes/Backup-External/MyDocs.
# Usage: rsync_docs [--dry-run]

set -euo pipefail

SRC="$HOME/Documents/MyDocs"
BASE_EXTERNAL="/Volumes/Backup-External"
DEST="$BASE_EXTERNAL/MyDocs"

# ── Argument parsing ──────────────────────────────────────────────────────────
DRY_RUN=0

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=1 ;;
    *) echo "Unknown argument: $arg"; echo "Usage: rsync_docs [--dry-run]"; exit 1 ;;
  esac
done

# ── External drive check ──────────────────────────────────────────────────────
if [[ ! -d "$BASE_EXTERNAL" ]]; then
  echo "ERROR: External drive not mounted at $BASE_EXTERNAL — aborting."
  exit 1
fi

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE="$HOME/Logs/rsync/sync_docs.log"
mkdir -p "$HOME/Logs/rsync"

echo "════════ $(date '+%Y-%m-%d %H:%M:%S') ════════" > "$LOG_FILE"

# ── rsync options ─────────────────────────────────────────────────────────────
RSYNC_OPTS=(
  -a
  --no-owner
  --no-group
  --delete
  --crtimes
  --human-readable
  --info=progress2
  --stats
  --mkpath
  --exclude=".DS_Store"
  --exclude="Desktop.ini"
  --log-file="$LOG_FILE"
  --log-file-format=""
)

if (( DRY_RUN )); then
  RSYNC_OPTS+=(--dry-run)
  echo "*** DRY RUN — no files will be changed ***"
  echo
fi

echo "Logging to: $LOG_FILE"
echo

# ── Shared sync function ──────────────────────────────────────────────────────
FAILED=()

run_sync() {
  local label="$1" src="$2" dst="$3"
  shift 3

  echo "" >> "$LOG_FILE"
  echo "── $label" >> "$LOG_FILE"
  echo "   $src" >> "$LOG_FILE"
  echo "   → $dst" >> "$LOG_FILE"

  echo "──────────────────────────────────────────"
  echo "[$label]"
  echo "  $src"
  echo "  → $dst"
  echo

  if [[ ! -d "$src" ]]; then
    echo "   SKIPPED — source does not exist" >> "$LOG_FILE"
    echo "  SKIPPED — source does not exist"
    echo
    return
  fi

  if ! rsync "${RSYNC_OPTS[@]}" "$@" "$src/" "$dst/"; then
    echo "  FAILED — see log for details"
    FAILED+=("$label")
  fi
  echo
}

# ── Sync tasks ────────────────────────────────────────────────────────────────
run_sync \
  "Docs - MyDocs" \
  "$SRC" \
  "$DEST"

# ── Summary ───────────────────────────────────────────────────────────────────
echo "" >> "$LOG_FILE"
echo "════════════════════════════════════════" >> "$LOG_FILE"
if (( ${#FAILED[@]} > 0 )); then
  echo "Result: completed with errors" >> "$LOG_FILE"
  for task in "${FAILED[@]}"; do
    echo "   ✗ $task" >> "$LOG_FILE"
  done
else
  echo "Result: all tasks succeeded" >> "$LOG_FILE"
fi
echo "Finished: $(date '+%Y-%m-%d %H:%M:%S')" >> "$LOG_FILE"

echo "══════════════════════════════════════════"
if (( ${#FAILED[@]} > 0 )); then
  echo "Docs sync completed with errors. Failed tasks:"
  for task in "${FAILED[@]}"; do
    echo "  ✗ $task"
  done
  echo "Log: $LOG_FILE"
  exit 1
else
  echo "Docs sync complete — all tasks succeeded."
  echo "Log: $LOG_FILE"
fi
