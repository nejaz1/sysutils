#!/bin/bash
# Transcribe audio from audio files, voice notes into meeting notes text
# Run from the directory containing the audio files

# The function will:
# 1. search for all audio files in the directory, source audio files could be .mp3, .mp4, .m4a, .wav
# 2. (if not already in wav format) first use ffmpeg to convert audio files in the directory are .mp3, .mp4, .m4a, into wav, 16-bit files
# 3. for all *.wav files, transcribe the audio into text using the whisper-cli binary
# 4. text files will be saved in the same directory as the audio files, with the same name as the audio files, but with the extension .txt

set -euo pipefail

command -v ffmpeg >/dev/null || { echo "ffmpeg not found"; exit 1; }
command -v whisper-cli >/dev/null || { echo "whisper-cli not found"; exit 1; }

MODEL="$HOME/Models/whisper-models/ggml-medium.bin"
[[ -f "$MODEL" ]] || { echo "Model not found: $MODEL"; exit 1; }

# Convert *.mp3, *.mp4, *.m4a to *.wav if not already in wav format
for audio in *.mp3 *.mp4 *.m4a; do
    [[ -f "$audio" ]] || continue
    stem="${audio%.*}"
    if [[ ! -f "$stem.wav" ]]; then
        echo "Converting: $audio"
        ffmpeg -y -i "$audio" -ar 16000 -ac 1 -c:a pcm_s16le "${stem}.wav"
    fi
done

# Transcribe all *.wav files using whisper-cli
shopt -s nullglob
wavs=(*.wav)
shopt -u nullglob
if [[ ${#wavs[@]} -eq 0 ]]; then
    echo "No WAV files found."; exit 1
fi
for wav in "${wavs[@]}"; do
    stem="${wav%.wav}"
    if [[ -f "$stem.txt" ]]; then
        echo "Skipping: $stem"
        continue
    fi
    echo "Transcribing: $stem"
    whisper-cli --model "$MODEL" --output-file "$stem" --output-txt --language en "$wav"
done

echo "Done."
