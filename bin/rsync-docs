#!/usr/bin/env zsh
set -euo pipefail

source "${0:A:h}/lib-rsync"

SRC="$HOME/Documents/MyDocs"
BASE_EXTERNAL="/Volumes/Backup-External"
DEST="$BASE_EXTERNAL/MyDocs"

case "${1:-}" in
  run)
    DRY_RUN=0
    shift
    for arg in "$@"; do
      case "$arg" in
        --dry-run) DRY_RUN=1 ;;
        *) echo "Unknown argument: $arg"; echo "Usage: rsync-docs run [--dry-run]"; exit 1 ;;
      esac
    done

    # ── External drive check ────────────────────────────────────────────────────
    if [[ ! -d "$BASE_EXTERNAL" ]]; then
      echo "ERROR: External drive not mounted at $BASE_EXTERNAL — aborting."
      exit 1
    fi

    # ── Logging ─────────────────────────────────────────────────────────────────
    LOG_FILE="$HOME/Logs/rsync/sync_docs.log"
    mkdir -p "$HOME/Logs/rsync"
    echo "════════ $(date '+%Y-%m-%d %H:%M:%S') ════════" > "$LOG_FILE"

    build_rsync_opts
    echo "Logging to: $LOG_FILE"
    echo

    # ── Sync tasks ───────────────────────────────────────────────────────────────
    run_sync "Docs - MyDocs" "$SRC" "$DEST"

    # ── Summary ──────────────────────────────────────────────────────────────────
    print_summary "Docs"
    ;;

  --help)
    echo "Usage: rsync-docs <command>"
    echo ""
    echo "Syncs ~/Documents/MyDocs to /Volumes/Backup-External/MyDocs."
    echo "Requires the external drive to be mounted at /Volumes/Backup-External."
    echo ""
    echo "Commands:"
    echo "  run          Execute the sync"
    echo "  --help       Show this help message"
    echo ""
    echo "Options for run:"
    echo "  --dry-run    Preview changes without writing any files"
    echo ""
    echo "Log: ~/Logs/rsync/sync_docs.log"
    ;;

  "")
    echo "Usage: rsync-docs <command>"
    echo "Run 'rsync-docs --help' for available commands."
    ;;

  *)
    echo "Unknown command: $1"
    echo "Run 'rsync-docs --help' for available commands."
    exit 1
    ;;
esac
