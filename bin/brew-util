#!/bin/zsh
set -euo pipefail

require_brewfile() {
  if [[ ! -f "${HOMEBREW_BUNDLE_FILE_GLOBAL:-}" ]]; then
    echo "Error: Global Brewfile not found at ${HOMEBREW_BUNDLE_FILE_GLOBAL:-<unset>}"
    exit 1
  fi
}

case "${1:-}" in
  --help)
    echo "Usage: brew-util <command>"
    echo ""
    echo "Commands:"
    echo "  update    Update Brew, upgrade packages from global .Brewfile, run doctor (bre-util save is run automatically)"
    echo "  install   Install Homebrew and all packages from global Brewfile"
    echo "  save      Save current Brew packages to global Brewfile"
    echo "  --help    Show this help message"
    ;;

  install)
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    echo "Brew installed."
    brew bundle install --global --cleanup
    echo "Packages installed from global Brewfile."
    ;;

  update)
    require_brewfile
    brew update --force
    brew autoremove
    brew-util save
    brew bundle install --global --cleanup
    brew doctor || true
    echo "Brew update complete."
    ;;

  save)
    require_brewfile
    brew bundle dump --global --force --no-vscode
    echo "Brew packages saved to $HOMEBREW_BUNDLE_FILE_GLOBAL"
    ;;

  "")
    echo "Usage: brew-util <command>"
    echo "Run 'brew-util --help' for available commands."
    ;;

  *)
    echo "Unknown command: $1"
    echo "Run 'brew-util --help' for available commands."
    exit 1
    ;;
esac
