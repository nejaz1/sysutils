#!/bin/zsh
set -euo pipefail

# validate global brewfile exists
if [[ ! -f "$HOMEBREW_BUNDLE_FILE_GLOBAL" ]]; then
  echo "Error: Global brewfile not found at $HOMEBREW_BUNDLE_FILE_GLOBAL"
  exit 1
fi

# update brew, cleanup unused packages
brew update --force
brew autoremove

# backup global brew bundle (excluding vscode)
brew bundle dump --global --force --no-vscode

# check for doctor warnings (don't fail on warnings)
brew doctor || true

# install from saved global brew bundle and cleanup
brew bundle install --global --cleanup

echo "Brew backup and update complete."
